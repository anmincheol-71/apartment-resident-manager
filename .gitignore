# ============================================
# Qt Creator - 개인 설정 파일 (커밋 금지)
# ============================================
*.pro.user
*.pro.user.*
*.autosave
*.qbs.user
*.qbs.user.*
CMakeLists.txt.user*

# ============================================
# 자동 생성 파일 (qmake/moc/uic/rcc가 생성)
# ============================================
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
Makefile
Makefile.*
*.qmlc
*.jsc

# ============================================
# 빌드 산출물
# ============================================
build/
build-*/
debug/
release/
*.o
*.obj
*.exe
*.app
*.so
*.dylib
*.dll
*.lib
*.a

# ============================================
# CMake (사용 시)
# ============================================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# ============================================
# IDE / 에디터
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# OS 생성 파일
# ============================================
Thumbs.db
.DS_Store
desktop.ini

# ============================================
# SQLite 로컬 DB (seed.sql로 재생성 가능)
# 샘플 DB를 함께 제출하고 싶으면 이 규칙을 제거
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# Qt 번역 컴파일 결과 (.ts는 커밋, .qm은 제외)
# ============================================
*.qm
